71,0.01902259,0.04711608,-0.02523764,0.0105892,0.04793166,0.21547309,0.01884291,0.00935977,0.00352758,-0.00359308,0.02046688,0.08371335,0.03545549,-0.02115197,-0.03216597,0.11745068,-0.01124074,0.05363295,0.02566352,-0.00344501,0.05463187,0.07112655,-0.02747936,0.01774799,-0.01760759,-0.0312905,0.02729816,0.06851153,-0.00046336,0.00274344,-0.06519322,0.02159844,0.04974046,-0.03728317,0.0107815,0.00853518,0.02238735,-0.00005217,-0.00098232,-0.01014268,-0.05398879,-0.0357104,-0.0456693,0.01894328,0.00257199,0.04276831,0.10220808,0.05383543],"last_embed":{"hash":"19h0jjd","tokens":396}}},"last_read":{"hash":"19h0jjd","at":1769676357695},"class_name":"SmartSource","last_import":{"mtime":1765759158000,"size":4650,"at":1769676327167,"hash":"19h0jjd"},"blocks":{"#":[1,16],"##{1}":[1,2],"##{2}":[3,3],"##{3}":[6,11],"##{4}":[12,12],"##{5}":[13,13],"##{6}":[14,16]},"outlinks":[{"title":"联想","target":"联想.md","line":1},{"title":"综合法","target":"综合法.md","line":2},{"title":"5.15.1 演绎法 演绎法是从普遍性的规律（如概念、公理、定理等）出发去认识特殊的，个 别的研究对象的方法，即从一般到特殊的推理方法。 演绎法是数学推理的重要方法，其基本模式是三段论法，即：128 第五章 数列、数学归纳法、数列的极限 1. 大前提：已知的一般原理， 2. 小前提：所研究特殊事物的特征， 3. 结论：从已知的一般原理结合特殊事物的特征做出的判断。 例如，对 y = f (x) 定义域内任何 x，都有 f (−x) = −f (x), 则 f (x) 是 奇函数。今有函数 f (x) = −x3 + sin x. 显然 f (−x) = −(−x)3 + sin(−x) = x3 − sin x = −f (x)，故 f (x) 是奇函数.","target":"北京四中高中教学讲义\n代数（第二册）/Highlights/Page 133/5.15.1 演绎法 演绎法是从普遍性的规律（如概念、公理、定理等）出发去认识特殊的，个 别的研究对象的方法，即从一般到特殊的推理方法。 演绎法是数学推理的重要方法，其基本模式是三段论法，即：128 第五章 数列、数学归纳法、数列的极限 1. 大前提：已知的一般原理， 2. 小前提：所研究特殊事物的特征， 3. 结论：从已知的一般原理结合特殊事物的特征做出的判断。 例如，对 y = f (x","line":11},{"title":"充分条件","target":"充分条件.md","line":12},{"title":"分析法","target":"演绎法.md","line":12},{"title":"分析法","target":"演绎法.md","line":13},{"title":"综合法","target":"综合法.md","line":13}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"19h0jjd","at":1769676357601}},"smart_blocks:RemNoteExport_xdf--math_md_2026-01-29_04-43/演绎法.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06132727,-0.02655345,0