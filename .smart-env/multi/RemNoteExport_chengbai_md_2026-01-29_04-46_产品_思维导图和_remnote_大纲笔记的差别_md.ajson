,-0.03870277,0.05889596,0.20697676,0.07658592,-0.00094695,0.00672168,-0.0000296,0.02129172,0.09145974,0.02177731,-0.02939309,-0.00828454,0.0494508,-0.01095142,0.04722586,0.08915786,-0.0235758,0.05122923,0.04016314,0.01308707,0.01305761,0.00811586,-0.07201891,0.02336598,0.14139295,0.03362031,-0.03140527,-0.06701735,0.00082673,0.01858796,-0.04634302,-0.02010021,0.01750684,0.01764654,0.01046297,0.04305834,0.00439334,-0.05091265,-0.02095198,-0.00953901,0.02217707,0.00041925,0.01579134,0.0639757,0.03906881],"last_embed":{"hash":"vpis8y","tokens":42}}},"text":null,"length":0,"last_read":{"hash":"vpis8y","at":1769676488102},"key":"RemNoteExport_chengbai_md_2026-01-29_04-46/产品/思维导图和 remnote 大纲笔记的差别.md#","lines":[1,6],"size":2574,"outlinks":[{"title":"比如 remonte 可以做一个前端提示链接的功能，保持高亮。目的是解决思维导图可以非常轻松的现实不同主题之间的关系，利用图形。但是 remnote 这样的大纲笔记的双链形式还不够直观，被链接的 rem 不知道是哪一个链接了它，体验不够直观。","target":"../💡P.A.R.A/😎归档/叮咚经历/找叮咚工作的积累/叮咚买菜招聘准备/自己的优势 ，特点  展现自己的品质  品质+细节/对于流程优化，和效率有追求。/自己的优势，自己产品能力的体现，会经常对喜欢产品like  remnote提出反馈意见，和社区里同样使用软件的小伙伴交流，并且帮助他们入门一些好用的技巧，也会冒出一些产品的新点子然后提交到论坛里和大家讨论。/比如 remonte 可以做一个前端提示链接的功能，保持高亮。目的是解决思维导图可以非常轻松的现实不同主题之间的关系，利用图形。但是 remnote 这样的大纲笔记的双链形式还不够直观，被链接的 rem 不知道是哪一个链接了它，体验不够直观。.md","line":5}],"class_name":"SmartBlock","last_embed":{"hash":"vpis8y","at":1769676488102}},
