 ，\n根据反比例函数 $y=\\frac{1}{-x}$ 的平移可得到 $f(x)$ ，则此时 $f(x)$ 单调递增, 作出图像如下图所示,\n\n第二步:\n令\n\n$$\ng(x)=f(x)-m x+\\frac{2}{3} m=0\n$$\n\n即\n![","target":"https://cdn.mathpix.com/cropped/2024_10_24_47a253f79e08acf28419g-26.jpg?height=429&width=577&top_left_y=314&top_left_x=1342","line":526}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"3nne2h","at":1771213650307}},"smart_blocks:00-知识汇总/10-试卷汇总/试卷 md 版本/功底考16题1-16套.md#科目二答题示例": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.08020997,-0.01170912,0.02811809,-0.0647328,0.00560066,0.00610495,-0.00138043,-0.01952359,0.03179337,-0.00572518,0.03281493,-0.02977106,0.04166278,-0.00615079,0.01887059,0.03654562,-0.02146209,-0.02954112,-0.08252412,0.00673413,0.13024265,-0.03965859,-0.01099419,-0.06114206,0.02387773,0.04809311,0.00132553,-0.03077747,-0.01231645,-0.17526667,0.00220495,0.01066821,0.00363663,0.03101314,0.04356554,-0.06058408,-0.02988182,0.06090626,-0.05738744,0.03691227,-0.01256945,0.06909885,0.0594343,-0.02817551,0.01311808,-0.04416941,-0.03078297,-0.01856631,0.03523862,-0.0264189,-0.05347434,-0.01535464,-0.02546359,0.03375194,0.03837434,-0.00763158,-0.016736,0.06463402,0.0150215,-0.02851178,0.04476276,0.02139127,-0.22253366,0.01765987,0.04603307,-0.00681153,0.00422113,-0.0336571,0.03554031,0.06532509,-0.04518295,0.01411505,0.02163895,0.04995631,-0.02137965,-0.02185312,0.02809378,-0.00948439,-0.07705532,-0.01594015,-0.01764603,0.06072972,0.03887638,0.00011941,-0.00941883,-0.00474057,0.03245986,-0.03937718,-0.01367297,-0.03668856,-0.01339179,-0.00378626,-0.0024008,0.04753832,-0.04720356,0.00637628,0.03586259,0.04239607,-0.03801676,0.09603569,-0.0331191,0.08825208,-0.02795588,-0.10325149,0.01352662,-0.05654175,-0.03176045,-0.07787398,-0.05238381,-0.03783977,-0.04367374,-0.00476681,0.07647558,-0.08560466,-0.00204215,-0.00689565,0.07801656,0.03513883,-0.01814083,-0.02435374,0.04267316,0.05700783,0.03048365,-0.0282201,-0.0024352,-0.05391473,0.02887734,-0.0027627,0.06209951,0.05714568,0.04