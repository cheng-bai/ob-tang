}$ ，\n根据反比例函数 $y=\\frac{1}{-x}$ 的平移可得到 $f(x)$ ，则此时 $f(x)$ 单调递增, 作出图像如下图所示,\n\n第二步:\n令\n\n$$\ng(x)=f(x)-m x+\\frac{2}{3} m=0\n$$\n\n即\n![","target":"https://cdn.mathpix.com/cropped/2024_10_24_47a253f79e08acf28419g-26.jpg?height=429&width=577&top_left_y=314&top_left_x=1342","line":526}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"3nne2h","at":1773193644247}},"smart_blocks:试卷汇总/10-试卷汇总/试卷 md 版本/功底考16题1-16套.md#科目二答题示例": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0746941,-0.00178013,0.03449553,-0.06359057,-0.00224147,0.0102165,0.00397923,-0.02623359,0.02507817,-0.0067201,0.03462241,-0.03531779,0.04648766,-0.00973537,0.02368249,0.04191485,-0.0312741,-0.02403256,-0.07555211,0.00700483,0.1371448,-0.03056404,-0.00409617,-0.05521255,0.02628161,0.0458588,0.01023839,-0.02576438,-0.01290185,-0.18583758,0.00315884,0.00965991,-0.00892117,0.03197207,0.03846505,-0.0596578,-0.02224987,0.06995367,-0.06984197,0.04234721,-0.00528738,0.064728,0.06427506,-0.02924392,0.0069109,-0.03987054,-0.0203472,-0.02583386,0.03304325,-0.03372176,-0.04511023,-0.01340626,-0.02415374,0.02891302,0.03173811,-0.00936742,-0.0177531,0.08182619,0.02270944,-0.0377684,0.04792328,0.02781082,-0.22161125,0.00738023,0.05083707,-0.01260203,-0.01092001,-0.04348469,0.04330696,0.05676445,-0.04687023,0.01749536,0.01600143,0.04975288,-0.02037747,-0.02045291,0.04220447,-0.00852351,-0.07450868,-0.01651853,-0.02125414,0.08130698,0.03316168,-0.00983144,-0.00599291,0.00701267,0.01783194,-0.05070525,-0.01806808,-0.05410207,-0.01107026,-0.00943948,0.00587729,0.0545214,-0.05085084,0.00895795,0.04014545,0.0309729,-0.0271598,0.09651303,-0.02727688,0.09137347,-0.01806975,-0.10707089,0.00455595,-0.0546454,-0.03250346,-0.07299396,-0.0427091,-0.03469918,-0.04534131,-0.02233901,0.07893026,-0.07021841,-0.01742563,-0.01867593,0.07479064,0.04117507,-0.03375735,-0.02837176,0.04089013,0.0503092,0.03835978,-0.03110197,-0.00797298,-0.05959617,0.02750461,-0.0030264,0.06159267,0.05495541,0.0417744,-0