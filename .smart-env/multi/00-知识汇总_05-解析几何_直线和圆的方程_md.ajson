向平移，如下图所示。\n![","target":"https://cdn.mathpix.com/cropped/2025_02_16_9e2b4e805b8d5043fc44g-280.jpg?height=510&width=493&top_left_y=587&top_left_x=784","line":56}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1bypzhz","at":1771213586471}},"smart_blocks:00-知识汇总/05-解析几何/直线和圆的方程.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0877494,-0.02023647,0.06023235,-0.0511138,0.02751509,-0.00962626,0.00544498,-0.01289991,0.0553597,-0.0271659,0.01832485,-0.04129335,0.03889669,0.02785992,0.0238155,0.04102489,0.01745375,-0.046195,-0.02857718,-0.03736739,0.10214215,-0.07052583,-0.0199929,-0.00492838,0.03977809,-0.01648612,-0.0144618,-0.04170534,0.00477543,-0.13748574,-0.02993251,-0.00690443,0.04137525,0.01136387,0.01375405,-0.05113737,-0.05653833,0.0308805,-0.03309059,0.01560005,0.02550917,0.02683096,0.06537396,-0.03377052,0.02627378,-0.03080868,-0.00459812,-0.03601394,-0.00296242,-0.01921962,-0.06872882,-0.04614628,-0.0082848,0.03270145,-0.02698982,0.02585517,0.04040421,0.03434745,0.02883316,0.04311194,0.04694703,0.01671355,-0.2154672,0.04976214,0.04134448,-0.01345875,0.01455605,0.01889546,0.05395087,0.04484782,-0.06727961,0.00558986,-0.01643707,0.03208965,0.02687359,0.00950771,-0.03660476,-0.04908767,-0.04336927,-0.03960103,-0.02891757,0.0604588,0.00097625,0.01591463,-0.01273786,0.02201123,0.02325924,-0.06184854,0.00673188,0.02572274,0.00061175,-0.04649273,-0.0448804,0.04812954,-0.0386479,-0.01232118,0.02851929,0.0408353,-0.07087725,0.09201606,-0.04899115,0.0197413,-0.01969948,-0.01893839,0.03234454,-0.03799672,-0.02332559,-0.04864547,-0.0491386,0.02113437,-0.03581497,-0.02566021,0.08419795,-0.07410952,-0.00072997,0.055291,0.06703204,0.01298364,-0.00362442,0.01759823,-0.00525695,0.0342665,0.00790046,-0.01574124,0.03273593,-0.03693691,0.00686715,0.03930761,0.07390122,0.00607457,0.03459548,0.00793061,-0.04197625,-0.03890325,0.01005916,-0.06080114,-0.01464033,0.02649355,0.04105945,-0.09580417,-0.04657675,-0.08493069,0.00713097,-0.09297843