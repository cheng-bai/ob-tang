$ 满足 $k=\\tan \\varphi$ 。现在将图像沿水平方向平移，如下图所示。\n![","target":"https://cdn.mathpix.com/cropped/2025_02_16_9e2b4e805b8d5043fc44g-280.jpg?height=510&width=493&top_left_y=587&top_left_x=784","line":56}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1bypzhz","at":1771332777853}},"smart_blocks:00-知识汇总-数学知识按主题分类/05-解析几何/直线和圆的方程.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.08119716,-0.01413546,0.04366299,-0.04191434,0.02480436,-0.01512951,-0.0090161,-0.00397741,0.05469223,-0.02310094,0.0151348,-0.04543635,0.03704473,0.03129586,0.018432,0.0352361,0.01678831,-0.03953429,-0.01968189,-0.03108403,0.105294,-0.06266378,-0.01347983,-0.02674123,0.04202141,-0.01170606,-0.00133465,-0.04583742,0.01046918,-0.13892837,-0.02574394,0.00488749,0.04700193,0.01400726,0.0227388,-0.03789156,-0.0541159,0.02405937,-0.04205512,0.01430249,0.02313341,0.0324757,0.05745424,-0.02969479,0.03441491,-0.02113934,-0.01018733,-0.03955282,-0.00577804,-0.02376586,-0.08049734,-0.04932394,-0.02010837,0.04395305,-0.04081742,0.02640988,0.03768779,0.03849244,0.02142658,0.03079378,0.03219376,0.02479211,-0.22985534,0.0481662,0.04248277,-0.01815015,0.0115938,0.02194785,0.04860042,0.05738108,-0.05774821,0.00597238,-0.00001172,0.03573805,0.03043518,0.01503252,-0.03104065,-0.04712031,-0.03532375,-0.05601705,-0.02295842,0.05529406,0.01568964,0.00717653,-0.01581102,0.01559666,0.02013196,-0.09125537,0.00685868,0.01750325,0.01612753,-0.04348257,-0.04409494,0.04733395,-0.03873465,-0.01703036,0.01987833,0.04198528,-0.06224319,0.09091723,-0.06150488,0.02190731,-0.02586875,-0.00930334,0.02652547,-0.03855625,-0.00847563,-0.05916147,-0.04617614,0.01923868,-0.0302384,-0.01120145,0.08503912,-0.0688058,0.00442789,0.05723261,0.07381611,0.01256223,0.005297,0.01148796,-0.00201861,0.03690692,-0.00315061,-0.01943305,0.03878897,-0.04409789,0.00643657,0.03926472,0.07236973,-0.00073549,0.03749257,0.01405886,-0.04577156,-0.03325367,-0.00137581,-0.04849393,-0.02228639,0.02984554,0.02840869,-0.08913