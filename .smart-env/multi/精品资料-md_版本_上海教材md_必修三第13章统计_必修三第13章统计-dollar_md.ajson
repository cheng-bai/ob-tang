13}":[1323,1324],"##B 组[5]":[1325,1354],"##B 组[5]#{1}":[1327,1328],"##B 组[5]#{2}":[1329,1342],"##B 组[5]#{3}":[1343,1344],"##B 组[5]#{4}":[1345,1346],"##B 组[5]#{5}":[1347,1348],"##B 组[5]#{6}":[1349,1350],"##B 组[5]#{7}":[1351,1354],"##课后阅读":[1355,1356],"##统计学与流行病的预防":[1357,1368],"##统计学与流行病的预防#{1}":[1359,1368],"##附录":[1369,1370],"##随机数表":[1371,1373],"##随机数表#{1}":[1373,1373]},"outlinks":[{"title":"bo_d4slmv3ef24c73be0p20_0_0_1_1654_1150_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_0_0_1_1654_1150_0.jpg","line":3,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_1_244_490_206_251_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_1_244_490_206_251_0.jpg","line":17,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_5_184_230_329_328_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_5_184_230_329_328_0.jpg","line":109,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_9_217_710_261_213_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_9_217_710_261_213_0.jpg","line":213,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_10_348_1655_553_321_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_10_348_1655_553_321_0.jpg","line":267,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_17_603_1518_843_534_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_17_603_1518_843_534_0.jpg","line":455,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_18_241_1411_925_548_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_18_241_1411_925_548_0.jpg","line":495,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_19_572_241_936_548_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_19_572_241_936_548_0.jpg","line":501,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_20_533_225_184_248_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_20_533_225_184_248_0.jpg","line":523,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_20_293_1245_667_344_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_20_293_1245_667_344_0.jpg","line":535,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_21_644_1062_760_405_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_21_644_1062_760_405_0.jpg","line":559,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_22_156_1314_936_298_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_22_156_1314_936_298_0.jpg","line":575,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_23_594_1364_859_498_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_23_594_1364_859_498_0.jpg","line":597,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_25_610_1495_468_332_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_25_610_1495_468_332_0.jpg","line":663,"embedded":true},{"title":"1.50, 2.00) 范围内的频率最大, 每日摄取热量不足 1.50 千大卡或超过 2.00 千大卡的频率相对较小.\n\n(2)从表 13-5 中可以看出，样本中摄取热量范围在 [1.80,1.90)的女大学生的频率为 0.21 . 由于样本是随机抽取的, 因此可以估计该校女大学生每日摄取热量的范围在 [1.80,1.90)的概率是 0.21 , 或者说约有 21% 的该校女大学生每日摄取热量的范围在 $\\lbrack {1.80},{1.90})$ .\n\n在例 1 中, 如果想要使信息更为直观地呈现, 那么我们可以绘制频率分布直方图，用图中矩形的面积大小来反映分布情况.\n\n这组数据的频率分布直方图如图 13-5-1 所示.\n\n![bo_d4slmv3ef24c73be0p20_28_195_508_862_459_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_28_195_508_862_459_0.jpg","line":721},{"title":"1.80,1.90) 所对应的矩形面积最大, 并且整幅直方图具有一定的对称性. 由此可以推测该校女大学生每日摄取热量的范围集中在 [1.80,1.90) 附近, 摄取特别多的热量或特别少的热量的女大学生人数都较少.\n\n在本例中, 如果将样本容量取得足够大, 且分组的组距取得足够小, 那么相应的频率分布折线图将趋于一条光滑的曲线, 称为总体分布密度曲线 (图 13-5-2). 事实上, 尽管总体分布密度曲线是客观存在的, 但由于在实际中往往无法获得总体的数据, 因此无法精确地得到它的密度曲线, 只能通过样本的频率分布折线图来对总体分布的密度曲线进行估计. 一般来说, 样本容量越接近总体容量, 样本的频率分布折线图与总体分布密度曲线的贴近程度越高.\n\n![bo_d4slmv3ef24c73be0p20_28_216_1655_815_490_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_28_216_1655_815_490_0.jpg","line":733},{"title":"5.5,10.5)</td><td>1</td></tr><tr><td>[10.5,15.5)</td><td>2</td></tr><tr><td>[15.5,20.5)</td><td>3</td></tr><tr><td>[20.5,25.5)</td><td>5</td></tr><tr><td>[25.5,30.5)</td><td>4</td></tr><tr><td>[30.5,35.5)</td><td>3</td></tr><tr><td>[35.5,40.5)</td><td>2</td></tr></table>\n\n试估计一周内该校学生平均跑步累计数.\n\n解 先求出各区间的中点值: $8\\text{ 、 }{13}\\text{ 、 }{18}\\text{ 、 }{23}\\text{ 、 }{28}\\text{ 、 }{33}\\text{ 、 }{38}$ . 则一周内这 20 名学生跑步累计的平均数为\n\n$$\n\\frac{8 \\times  1 + {13} \\times  2 + \\cdots  + {38} \\times  2}{20} = {24.5}\\left( \\mathrm{\\;{km}}\\right) .\n$$\n\n由于这 20 名学生是随机抽取的, 因此可以估计一周内该校学生平均跑步累计约 ${24.5}\\mathrm{\\;{km}}$ .\n\n### 2.2 通过样本估计总体的离散程度\n\n现在我们介绍如何用数量来描述数据的另外一种统计特征一一样本数据的离散程度.\n\n在一次男子10 米气手枪射击比赛中, 甲运动员的成绩(单位: 环)为7.5、7.8、...、10.9；乙运动员的成绩为 8.4、8.5、...、 10.7 , 如图 13-5-3 所示.\n\n---\n\n原始记录没有提供每个数据的准确值, 只提供了它们所在的区间. 这时, 为了计算均值, 可用区间的中点值给区间内的每个数据赋值.\n\n---\n\n![bo_d4slmv3ef24c73be0p20_32_392_336_459_246_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_32_392_336_459_246_0.jpg","line":827},{"title":"bo_d4slmv3ef24c73be0p20_35_707_338_633_480_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_35_707_338_633_480_0.jpg","line":993,"embedded":true},{"title":"bo_d4slmv3ef24c73be0p20_41_1131_533_360_281_0.jpg","target":"images/bo_d4slmv3ef24c73be0p20_41_1131_533_360_281_0.jpg","line":1159,"embedded":true}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1d5zi4p","at":1773193864626}},"smart_blocks:精品资料-md 版本/上海教材md/必修三第13章统计/必修三第13章统计-dollar.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06169412,-0.02090815,0.00112919,-0.02608327,0.04310404,-0.04659694,-0.06246464,0.02790172,0.02994272,0.01044576,0.04861732,-0.07973813,0.04896996,0.01036405,0.02800561,-0.00355072,0.00838735,-0.04912613,-0.04970399,0.03134917,0.08888784,-0.05717738,0.03048218,-0.05709979,0.039975,0.03186295,0.02670485,0.0056508,0.0178249,-0.16357633,0.01745886,0.01951214,-0.00354241,-0.0178541,0.03668399,-0.01868775,-0.0860007,0.01229019,-0.0173888,-0.00208621,-0.04367016,0.00936287,0.05540973,-0.03645198,-0.00589229,-0.02238224,-0.00951716,0.0251328,0.06244355,-0.00361167,-0.01977569,0.0047353,-0.04431859,0.02410554,-0.01273655,-0.00890406,0.02891091,0.03603284,0.02702197,0.01965596,0.0821466,0.06401838,-0.23021406,0.05323931,0.00766996,-0.00068999,-0.02052859,0.02153729,0.01743043,0.07388429,-0.0243095,-0.00215883,-0.00764858,0.02479893,0.00152208,-0.07052097,0.03620014,0.00164429,-0.07338615,-0.05763602,-0.02207592,0.07573695,0.03437017,-0.0183