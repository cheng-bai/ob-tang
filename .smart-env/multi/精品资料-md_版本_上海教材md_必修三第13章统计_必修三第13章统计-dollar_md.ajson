
"smart_sources:精品资料-md 版本/上海教材md/必修三第13章统计/必修三第13章统计-dollar.md": {"path":"精品资料-md 版本/上海教材md/必修三第13章统计/必修三第13章统计-dollar.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1d5zi4p","at":1773193756991},"class_name":"SmartSource","last_import":{"mtime":1765366675000,"size":128932,"at":1773193757022,"hash":"1d5zi4p"},"blocks":{"#":[1,12],"###13.1 总体与样本":[13,38],"###13.1 总体与样本#{1}":[15,38],"##练习 13.1":[39,50],"##练习 13.1#{1}":[41,42],"##练习 13.1#{2}":[43,44],"##练习 13.1#{3}":[45,48],"##练习 13.1#{4}":[49,50],"##习题 13.1":[51,52],"##A 组":[53,68],"##A 组#{1}":[55,56],"##A 组#{2}":[57,58],"##A 组#{3}":[59,60],"##A 组#{4}":[61,66],"##A 组#{5}":[67,68],"##B 组":[69,142],"##B 组#{1}":[71,72],"##B 组#{2}":[73,76],"##B 组#{3}":[77,78],"##B 组#13.2 数据的获取":[79,142],"##B 组#13.2 数据的获取#{1}":[81,142],"##练习 13.2":[143,160],"##练习 13.2#{1}":[145,146],"##练习 13.2#{2}":[147,152],"##练习 13.2#{3}":[153,154],"##练习 13.2#{4}":[155,158],"##练习 13.2#{5}":[159,160],"##习题 13.2":[161,162],"##A 组[2]":[163,176],"##A 组[2]#{1}":[165,166],"##A 组[2]#{2}":[167,168],"##A 组[2]#{3}":[169,174],"##A 组[2]#{4}":[175,176],"##B 组[2]":[177,194],"##B 组[2]#{1}":[179,180],"##B 组[2]#{2}":[181,182],"##B 组[2]#{3}":[183,186],"##B 组[2]#13.3 抽样方法":[187,194],"##B 组[2]#13.3 抽样方法#{1}":[189,194],"##1 简单随机抽样":[195,208],"##1 简单随机抽样#{1}":[197,208],"##操作:制作随机数表":[209,262],"##操作:制作随机数表#{1}":[211,262],"##信息技术:利用计算机或计算器产生随机数":[263,278],"##信息技术:利用计算机或计算器产生随机数#{1}":[265,278],"##练习 13.3(1)":[279,290],"##练习 13.3(1)#{1}":[281,282],"##练习 13.3(1)#{2}":[283,286],"##练习 13.3(1)#{3}":[287,288],"##练习 13.3(1)#{4}":[289,290],"##2 分层随机抽样":[291,340],"##2 分层随机抽样#{1}":[293,340],"##操作:抽样调查本校学生的运动时间":[341,354],"##操作:抽样调查本校学生的运动时间#{1}":[343,354],"##练习13.3(2)":[355,366],"##练习13.3(2)#{1}":[357,358],"##练习13.3(2)#{2}":[359,362],"##练习13.3(2)#{3}":[363,364],"##练习13.3(2)#{4}":[365,366],"##习题 13.3":[367,368],"##A 组[3]":[369,404],"##A 组[3]#{1}":[371,372],"##A 组[3]#{2}":[373,380],"##A 组[3]#{3}":[381,382],"##A 组[3]#{4}":[383,384],"##A 组[3]#{5}":[385,398],"##A 组[3]#13.4