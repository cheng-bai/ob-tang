height=429&width=401&top__y=982&top__x=468","line":3169,"embedded":true},{"title":"50,60$ ) 内的人数为 16 ，则下列结论正确的是（）\n![","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-185.jpg?height=435&width=618&top__y=1781&top__x=296","line":3666}],"class_name":"SmartBlock","last_embed":{"hash":"19gd1oy","at":1773194259163}},
