a66ff94b9c61bg-053.jpg?height=427&width=401&top__y=980&top__x=468","line":1060,"embedded":true},{"title":"|764x188","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-055.jpg?height=256&width=1043&top__y=1369&top__x=362","line":1091,"embedded":true},{"title":"0, \\frac{\\sqrt{5}}{5}\\.$ )；\n(4) $\\triangle F M N$ 周长的最小值为 $\\sqrt{2}+1$.\n\n其中正确结论的为（）\nA. (1)(2)\nB. (2)(3)\nC. (3)(4)\nD. (1)(4)\n![","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-078.jpg?height=427&width=404&top__y=980&top__x=466","line":1534},{"title":"2,+\\infty)$\nD. $(-\\infty, 2) \\cup(2,+\\infty)$\n\n#### 10.2.2 【 练 1-1\n\n圆 $x^{2}+y^{2}+4 \\sin \\theta \\cdot x+4 \\cos \\theta \\cdot y+1=0$ 的半径等于 $\\qquad$ .\n\n#### 10.2.3 【 练 1-2\n\n已知 $A(-2,2) ， B(2,6)$ ，则以 $A B$ 为直径的圆的标准方程为 $\\qquad$ .\n\n#### 10.2.4 【 练 1-3\n\n正方形草地 $A B C D$ 边长 $1.2 ， E$ 到 $A B ， A D$ 距离为 $0.2 ， F$ 到 $B C ， C D$ 距离为 0.4 ，有个圆形通道经过 $E ， F$ ，且与 $A D$ 只有一个交点，求圆形通道的周长 $\\qquad$ . (精确到 $0.01)$\n![","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-118.jpg?height=318&width=304&top__y=889&top__x=299","line":2226},{"title":"                                                             | 201x197","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-144.jpg?height=197&width=201&top__y=1293&top__x=738","line":2683,"embedded":true},{"title":"                                                             | 212x197","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-144.jpg?height=197&width=212&top__y=1513&top__x=723","line":2684,"embedded":true},{"title":"                                                             | 201x156","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-144.jpg?height=156&width=201&top__y=1742&top__x=738","line":2685,"embedded":true},{"title":"|401x429","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-161.jpg?height=429&width=401&top__y=982&top__x=468","line":3034,"embedded":true},{"title":"50,60$ ) 内的人数为 16 ，则下列结论正确的是（）\n![","target":"https://cdn.mathpix.com/cropped/2024_11_11_d544063a66ff94b9c61bg-185.jpg?height=435&width=618&top__y=1781&top__x=296","line":3503}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1c51oxn","at":1773194538854}},"smart_blocks:01零散资料/XDF讲义/FY25 高三数学秋季【行远班教材】修改版本.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05999767,-0.00881983,0.07204171,0.02938431,0.03711468,-0.00623188,-0.05674471,0.03402924,0.03789198,0.06000329,0.04240364,-0.07466219,0.03728943,-0.00103281,0.00848141,0.0022447,-0.0103553,-0.0350839,-0.05644332,-0.0145271,0.12843028,-0.00642202,-0.01517631,-0.05282941,0.04884668,0.06173179,-0.01913282,-0.08441956,-0.03149691,-0.19816038,-0.00363049,0.08709691,0.06186821,0.03474532,0.02982173,-0.06589463,-0.01785028,0.08257249,0.00432685,0.05359188,0.00209268,0.07503107,0.01617046,0.00287596,-0.01925454,-0.08379188,-0.06978838,-0.00726081,0.03780029,-0.00690577,-0.03094624,-0.01215534,0.00802647,0.02470969,-0.02225727,0.00206803,0.03422632,-0.00241839,0.04337927,0.03822733,0.02136503,-0.00704654,-0.22730075,0.03470032,0.0531022,-0.02312256,-0.02653538,-0.05828086,0.01191155,0.06887488,-0.01896499,0.00657361,0.0035455,0.00604925,-0.01967504,-0.03712099,-0.00869128,-0.0828456,-0.03636359,-0.03787447,-0.04097199,0.08966083,-0.05741855,0.00405317,-0.01417937,0.06430411,0.01098885,-0.05149141,0.0086225,-0.00474574,-0.00240163,-0.01058534,-0.02647572,0.01196647,-0.09379458,-0.05959926,0.02692309,0.00341722,-0.01043471,0.0670356,-0.03108323,-0.01197455,0.02715021,-0.00807815,-0.0431223,0.04495918,-0.01716933,-0.08007655,-0.02451385,0.00335318,0.00467884,-0.01919622,0.09248968,-0.04900208,-0.03609205,-0.00303951,-0.057604,-0.03692853,-0.01244863,0.02237043,0.0100097,0.00863639,0.03328739,0.00513846,0.02583391,-0.00957737,-0.00444161,0.02414092,-0.00016101,0.04329993,0.02455332,-0.00288367,-0.01876857,-0.02036756,-0.03023897,0.02684786,-0.019