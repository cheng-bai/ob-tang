$ 的平移可得到 $f(x)$ ，则此时 $f(x)$ 单调递增, 作出图像如下图所示,\n\n第二步:\n令\n\n$$\ng(x)=f(x)-m x+\\frac{2}{3} m=0\n$$\n\n即\n![","target":"https://cdn.mathpix.com/cropped/2024_10_24_47a253f79e08acf28419g-26.jpg?height=429&width=577&top_left_y=314&top_left_x=1342","line":526}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"3nne2h","at":1773194012054}},"smart_blocks:试卷汇总/功底考16题1-16套.md#科目二答题示例": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04437783,-0.00420882,0.03828169,-0.04926387,0.00047537,0.00026542,0.01105341,-0.03735374,0.04142391,0.00511912,0.03235674,-0.04726375,0.04231595,-0.02092211,0.03207016,0.03169809,-0.01308569,-0.03393143,-0.08252452,-0.00560961,0.13610525,-0.03240462,-0.02211904,-0.06548228,0.04165422,0.05096927,0.02690566,-0.06263994,-0.00819053,-0.19147348,0.00444628,0.01933083,-0.00961623,0.02792042,0.03469261,-0.03684608,-0.0231138,0.07162254,-0.06097431,0.03663926,-0.01550691,0.07598799,0.04819927,-0.01592684,0.03395675,-0.03596401,-0.00568928,-0.03514931,0.01392364,-0.01544941,-0.05005266,0.00924447,-0.01878335,0.02432391,0.04618945,-0.00238728,-0.01139909,0.0702253,-0.00253585,-0.01119872,0.06738795,0.00760728,-0.21412769,-0.0022948,0.02516355,-0.00462613,-0.01439943,-0.0667854,0.04017042,0.07458164,-0.03112333,0.02183295,0.01505004,0.06326669,0.00318324,-0.00670057,0.01509669,0.0021648,-0.08729197,-0.01917221,-0.01695436,0.08784079,0.02630266,-0.00372733,-0.01615825,-0.00889389,0.01154564,-0.07494315,-0.01398494,-0.04112127,0.00896845,-0.01233923,0.02915777,0.03831378,-0.05428962,0.02589761,0.04898852,0.02647857,-0.02040827,0.09422494,-0.03759767,0.07800741,-0.0239899,-0.09812807,0.0142406,-0.04984767,-0.04267627,-0.07703939,-0.01979685,-0.00921352,-0.04091282,-0.02199362,0.06362419,-0.09118137,-0.00788571,-0.00538029,0.0632963,0.04402128,-0.01653971,-0.00722581,0.04860118,0.06455774,0.03565674,-0.01949679,-0.00807776,-0.06174985,0.01604711,-0.00566634,0.07046387,0.06059098,0.03704642,-0.00556869,0.0432571,0.0351654,-0.014