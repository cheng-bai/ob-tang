
"smart_sources:01-数学教学/试卷/功底考/FY25功底考-解析版1-10_81-120 1.md": {"path":"01-数学教学/试卷/功底考/FY25功底考-解析版1-10_81-120 1.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"4zmisu","at":1769671056543},"class_name":"SmartSource","last_import":{"mtime":1733900153000,"size":56656,"at":1769671056557,"hash":"4zmisu"},"blocks":{"#":[1,11],"##上海市崇明区 2024 届高三二模数学试题":[12,13],"##一、填空题":[14,17],"##一、填空题#{1}":[16,17],"##【答案】 $A \\cap B=\\{-2,1\\}$":[18,19],"##【解析】":[20,28],"##【解析】#{1}":[22,26],"##【解析】#{2}":[27,28],"##【答案】 $(0,1)$":[29,30],"##【解析】[2]":[31,39],"##【解析】[2]#{1}":[33,37],"##【解析】[2]#{2}":[38,39],"##【答案】 -8":[40,41],"##【解析】[3]":[42,50],"##【解析】[3]#{1}":[44,48],"##【解析】[3]#{2}":[49,50],"##【答案】 $1-i$":[51,61],"##【答案】 $1-i$#{1}":[53,59],"##【答案】 $1-i$#{2}":[60,61],"##【答案】 9":[62,63],"##【解析】[4]":[64,74],"##【解析】[4]#{1}":[66,72],"##【解析】[4]#{2}":[73,74],"##【答案】 9[2]":[75,76],"##【解析】[5]":[77,85],"##【解析】[5]#{1}":[79,83],"##【解析】[5]#{2}":[84,85],"##【答案】 1":[86,87],"##【解析】[6]":[88,98],"##【解析】[6]#{1}":[90,94],"##【解析】[6]#{2}":[95,96],"##【解析】[6]#{3}":[97,98],"##【解析】[7]":[99,111],"##【解析】[7]#{1}":[101,109],"##【解析】[7]#{2}":[110,111],"##【答案】 $-\\frac{19}{9}$":[112,113],"##【解析】[8]":[114,124],"##【解析】[8]#{1}":[116,122],"##【解析】[8]#{2}":[123,124],"##【答案】 0.996":[125,126],"##【解析】[9]":[127,140],"##【解析】[9]#{1}":[129,136],"##【解析】[9]#{2}":[137,138],"##【解析】[9]#{3}":[139,140],"##【解析】[10]":[141,162],"##【解析】[10]#{1}":[143,160],"##【解析】[10]#{2}":[161,162],"##【答案】 6":[163,164],"##【解析】[11]":[165,178],"##【解析】[11]#{1}":[167,178],"##二、单选题":[179,186],"##二、单选题#{1}":[181,181],"##二、单选题#{2}":[182,186],"##【答案】A":[187,188],"##【解析】[12]":[189,204],"##【解析】[12]#{1}":[191,198],"##【解析】[12]#{2}":[199,199],"##【解析】[12]#{3}":[200,204],"##【答案】C":[205,208],"##【答案】C#{1}":[207,208],"##【解析】[13]":[209,223],"##【解析】[13]#{1}":[211,217],"##【解析】[13]#{2}":[218,218],"##【解析】[13]#{3}":[219,223],"##【答案】B":[224,246],"##【答案】B#{1}":[226,235],"##【答案】B#{2}":[236,237],"##【答案】B#{3}":[238,246],"##【答案】 C":[247,248],"##【解析】[14]":[249,293],"##【解析】[1