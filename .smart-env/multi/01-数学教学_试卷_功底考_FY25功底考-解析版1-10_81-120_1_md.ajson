7,612],"##【解析】[34]#{1}":[589,602],"##【解析】[34]#{2}":[603,604],"##【解析】[34]#{3}":[605,612],"##【解析】[35]":[613,628],"##【解析】[35]#{1}":[615,626],"##【解析】[35]#{2}":[627,628],"##【答案】 3":[629,630],"##【解析】[36]":[631,646],"##【解析】[36]#{1}":[633,641],"##【解析】[36]#{2}":[642,642],"##【解析】[36]#{3}":[643,646],"##【解析】[37]":[647,672],"##【解析】[37]#{1}":[649,666],"##【解析】[37]#{2}":[667,667],"##【解析】[37]#{3}":[668,672],"##【答案】A[2]":[673,674],"##【解析】[38]":[675,686],"##【解析】[38]#{1}":[677,680],"##【解析】[38]#{2}":[681,681],"##【解析】[38]#{3}":[682,686],"##【答案】 $C$":[687,688],"##【解析】[39]":[689,706],"##【解析】[39]#{1}":[691,700],"##【解析】[39]#{2}":[701,701],"##【解析】[39]#{3}":[702,706],"##【答案】 B":[707,708],"##【解析】[40]":[709,733],"##【解析】[40]#{1}":[711,714],"##【解析】[40]#{2}":[715,715],"##【解析】[40]#{3}":[716,733],"##【答案】 B[2]":[734,735],"##【解析】[41]":[736,757],"##【解析】[41]#{1}":[738,752],"##【解析】[41]#{2}":[753,753],"##【解析】[41]#{3}":[754,757],"##【解析】[42]":[758,764],"##【解析】[42]#{1}":[760,764],"##【解析】[43]":[765,773],"##【解析】[43]#{1}":[767,767],"##【解析】[43]#{2}":[768,768],"##【解析】[43]#{3}":[769,773],"##【解析】[44]":[774,785],"##【解析】[44]#{1}":[776,785],"##【解析】[45]":[786,824],"##【解析】[45]#{1}":[788,799],"##【解析】[45]#{2}":[800,800],"##【解析】[45]#{3}":[801,824],"##【解析】[46]":[825,884],"##【解析】[46]#{1}":[827,843],"##【解析】[46]#{2}":[844,844],"##【解析】[46]#{3}":[845,884],"##【答案】答案见解析":[885,886],"##【解析】[47]":[887,907],"##【解析】[47]#{1}":[889,907],"##【答案】答案见解析[2]":[908,909],"##【解析】[48]":[910,931],"##【解析】[48]#{1}":[912,928],"##【解析】[48]#{2}":[929,929],"##【解析】[48]#{3}":[930,931],"##【答案】详见解析;":[932,933],"##【解析】[49]":[934,952],"##【解析】[49]#{1}":[936,952],"##【解析】[50]":[953,977],"##【解析】[50]#{1}":[955,977],"##【解析】[51]":[978,1001],"##【解析】[51]#{1}":[980,1001],"##上海市黄浦区 2024 届高三二模数学试题":[1002,1007],"##上海市黄浦区 2024 届高三二模数学试题#{1}":[1004,1005],"##上海市黄浦区 2024 届高三二模数学试题#{2}":[1006,1007],"##【答案】 $[1,5]$":[1008,1009],"##【解析】[52]":[1010,1018],"##【解析】[52]#{1}":[1012,1016],"##【解析】[52]#{2}":[1017,1018],"##【答案】 2[2]":[1019,1023],"##【答案】 2[2]#{1}":[1021,1021],"##【答案】 2[2]#{2}":[1022,1023],"##【答案】 3[2]":[1024,1025],"##【解析】[53]":[1026,1033],"##【解析】[53]#{1}":[1028,1031],"##【解析】[53]#{2}":[1032,1033],"##【答案】 $12 \\pi$":[1034,1035],"##【解析】[54]":[1036,1043],"##【解析】[54]#{1}":[1038,1041],"##【解析】[54]#{2}":[1042,1043],"##【答案】 -2":[1044,1045],"##【解析】[55]":[1046,1057],"##【解析】[55]#{1}":[1048,1055],"##【解析】[55]#{2}":[1056,1057],"##【答案】 $4 \\sqrt{2}$":[1058,1059],"##【解析】[56]":[1060,1068],"##【解析】[56]#{1}":[1062,1068]},"outlinks":[{"title":"0,2 \\pi)$,\n\n因为 $x_{1} y_{2}-y_{1} x_{2}=1$ ，\n\n所以 $\\cos \\alpha \\sin \\beta-\\sin \\alpha \\cos \\beta=\\sin (\\beta-\\alpha)=1 \\Rightarrow \\beta-\\alpha=\\frac{\\pi}{2}$,\n所以 $\\left|x_{1}+y_{1}-2\\right|+\\left|x_{2}+y_{2}-2\\right|=4-\\left(x_{1}+y_{1}+x_{2}+y_{2}\\right)=4-(\\cos \\alpha+\\sin \\alpha+\\cos \\beta+\\sin \\beta)$\n$=4-\\left(\\cos \\alpha+\\sin \\alpha+\\cos \\left(\\alpha+\\frac{\\pi}{2}\\right)+\\sin \\left(\\alpha+\\frac{\\pi}{2}\\right)\\right)=4-2 \\cos \\alpha \\leq 4-(-2)=6$ ，仅当 $\\alpha=\\pi$ 时等号成立。\n\n关键点点睛：解决本题的关键是利用三角换元及三角方程，结合三角函数的性质即可。\n\n## 二、单选题\n\n13. 若 $a>b, c<0$ ，则下列不等式成立的是（ ）\nA. $a c^{2}>b c^{2}$\nB. $\\frac{a}{c}>\\frac{b}{c}$\nC. $a+c<b+c$\nD. $a>b-c$\n\n## 【答案】A\n\n## 【解析】\n\n对于 A. $c^{2}>0, a>b$, 则 $a c^{2}>b c^{2}$ ，成立\n对于 B. $\\frac{1}{c}<0, a>b, \\frac{a}{c}<\\frac{b}{c}$;\n\n对于 C. $a>b, a+c>b+c$ ；\n\n对于 D. 若 $a=1, b=0, c=-2$ ，则不成立\n\n故选 A.\n14. 某单位共有 $\\mathrm{A} 、 \\mathrm{~B}$ 两部门， 1 月份进行服务满意度问卷调查，得到两部门服务满意度得分的频率分布条形图如下。设 $\\mathrm{A} 、 \\mathrm{~B}$ 两部门的服务满意度得分的第 75 百分位数分别为 $n_{1}, n_{2}$ ，方差分别为 $s_{1}^{2}, s_{2}^{2}$ ，则 (）\nA. $n_{1}>n_{2}, s_{1}^{2}>s_{2}^{2}$\nB. $n_{1}>n_{2}, s_{1}^{2}<s_{2}^{2}$\nC. $n_{1}<n_{2}, s_{1}^{2}<s_{2}^{2}$\nD. $n_{1}<n_{2}, s_{1}^{2}>s_{2}^{2}$\n\n## 【答案】C\n\n![","target":"https://cdn.mathpix.com/cropped/2024_10_18_83fe5ee199bb5bf7a4aag-08.jpg?height=367&width=630&top_left_y=819&top_left_x=1247","line":169},{"title":"\\frac{\\pi}{3}, \\frac{2 \\pi}{3}\\right), m \\in\\left[\\frac{\\pi}{2}, \\frac{5 \\pi}{6}\\right)$.\n\n故选 B.\n\n本题主要考查了三角函数的图像和性质，考查了函数与方程的思想，正确理解两变量的关系是解题的关键，属于中档题。\n16. 已知函数 $y=f(x)$ 的定义域为 $D, x_{1}, x_{2} \\in D$.\n\n命题 $p$ : 若当 $f\\left(x_{1}\\right)+f\\left(x_{2}\\right)=0$ 时, 都有 $x_{1}+x_{2}=0$, 则函数 $y=f(x)$ 是 D 上的奇函数.\n\n命题 $q$ : 若当 $f\\left(x_{1}\\right)<f\\left(x_{2}\\right)$ 时, 都有 $x_{1}<x_{2}$, 则函数 $y=f(x)$ 是 D 上的增函数.\n下列说法正确的是（）\nA. $\\mathrm{p} 、 \\mathrm{q}$ 都是真命题\nB. p 是真命题, $q$ 是假命题\nC. p 是假命题, q 是真命题\nD. $\\mathrm{p} 、 \\mathrm{q}$ 都是假命题\n\n## 【答案】 C\n\n## 【解析】\n\n根据题意，结合函数奇偶性与单调性的定义及判定方法，即可求解。\n对于命题 $p$, 令函数 $f(x)=\\left\\{\\begin{array}{c}-x^{2}, x \\in(-\\infty, 1) \\cup(1,+\\infty) \\\\ 1, x=1\\end{array}\\right.$ ，\n则 $f(1)+f(-1)=0$, 此时 $1+(-1)=0$, 当函数 $y=f(x)$ 不是奇函数,\n所以命题 $p$ 为假命题,\n对于命题 $q$, 当 $f\\left(x_{1}\\right)<f\\left(x_{2}\\right)$ 时, 都有 $x_{1}<x_{2}$, 即 $x_{1}<x_{2}$, 不可能 $f\\left(x_{1}\\right) \\geq f\\left(x_{2}\\right)$,\n\n即当 $x_{1}<x_{2}$ 时, 可得 $f\\left(x_{1}\\right)<f\\left(x_{2}\\right)$, 满足增函数的定义, 所以命题 $q$ 为真命题.\n\n故选: C.\n\n三、解答题\n17. 如图, 在三棱雉 $P-A B C$ 中, $A B=B C=2 \\sqrt{2}, P A=P B=P C=A C=4, O$ 为 $A C$ 的中点.\n(1) 证明: $P O \\perp$ 平面 $A B C$;\n(2) 若点 $M$ 在棱 $B C$ 上, 且 $M C=2 M B$, 求点 $C$ 到平面 $P O M$ 的距离.\n\n【答案】(1) 详见解析（2） $\\frac{4 \\sqrt{5}}{5}$.\n![","target":"https://cdn.mathpix.com/cropped/2024_10_18_83fe5ee199bb5bf7a4aag-10.jpg?height=441&width=406&top_left_y=733&top_left_x=1473","line":231}],"task_lines":[],"tasks":{},"codeblock_ranges":[]},
