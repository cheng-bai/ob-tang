的平移可得到 $f(x)$ ，则此时 $f(x)$ 单调递增, 作出图像如下图所示,\n\n第二步:\n令\n\n$$\ng(x)=f(x)-m x+\\frac{2}{3} m=0\n$$\n\n即\n![","target":"https://cdn.mathpix.com/cropped/2024_10_24_47a253f79e08acf28419g-26.jpg?height=429&width=577&top_left_y=314&top_left_x=1342","line":526}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"3nne2h","at":1773194834896}},"smart_blocks:04-试卷汇总/功底考16题1-16套.md#科目二答题示例": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05152053,0.00883336,0.04380076,-0.04640808,0.01395013,0.01556584,0.01361545,-0.03800794,0.0414675,0.02743977,0.04022285,-0.03888974,0.04784693,-0.04208651,0.03276535,0.04448066,-0.0165821,-0.0501781,-0.07764998,-0.02142512,0.13516624,-0.0423152,-0.02097481,-0.06925015,0.03297447,0.06618147,0.01924278,-0.06329866,-0.01481709,-0.18995303,-0.01923772,0.02012474,-0.00306697,0.02066506,0.01560441,-0.02635982,-0.01748505,0.06005529,-0.06753187,0.01527605,-0.03051716,0.07842947,0.03012944,-0.0401657,0.0128724,-0.02923845,-0.02204277,-0.01444318,0.02555591,-0.01571039,-0.02952439,0.01576759,-0.01148793,0.03075285,0.04102432,-0.00196811,-0.0101613,0.06016868,-0.00838059,-0.01025776,0.06680954,0.01717577,-0.20171824,0.00744453,0.03908247,-0.02188165,-0.0045032,-0.05941453,0.0483455,0.0744233,-0.0507134,0.03262812,-0.00399727,0.06013834,-0.00543872,0.00408854,0.02153858,-0.01452038,-0.086827,-0.01050112,-0.02751714,0.09383565,0.02336313,0.00193349,-0.00779715,0.00452858,0.01379668,-0.09140292,-0.00392413,-0.02541772,-0.00276134,-0.01739089,0.0406219,0.03213079,-0.04592996,0.01585623,0.05318895,0.02753447,-0.01029312,0.09010174,-0.03448398,0.08988269,-0.02759187,-0.08328611,-0.00439692,-0.04739636,-0.03261778,-0.07013517,-0.01522282,0.01203347,-0.04151595,-0.02475374,0.06083919,-0.08068308,-0.01145669,-0.01427471,0.05580689,0.0341078,-0.02126658,-0.00406664,0.06015354,0.0524365,0.03909334,-0.0214275,-0.00800734,-0.05879702,0.01275864,0.00614665,0.06523488,0.05898309,0.05180702,-0.00684928,0.02067906,0.04071743,-0.02082507,-