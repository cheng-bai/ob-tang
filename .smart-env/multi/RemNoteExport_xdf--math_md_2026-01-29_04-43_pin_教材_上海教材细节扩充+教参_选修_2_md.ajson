om/YCz9s7izIprD92IgfW72kf7NnhYe4CWAjVCFaCIc1GospWAy0noIED9N-OzfGCM1klX4ETiTIt8VuObEBoTqL2sSBaKpdOeIb0lAjdKvhrhyoLhs7prvRvaa4kRMZojx.png","target":"../../../上传文件/教参-选修二/高亮标注/第 044 页/Untitled.md","line":41},{"title":"https://remnote-user-data.s3.amazonaws.com/yn_zkbhF8ht6c1zRaRQeIgXIkGylctc76BgvHCvBmM4nCHX5nk33zQ-WAYvu5BM5mCmPXuKyA6b0smI2OT_JF9UCUQBPFZ3eUYhnAlBsB_MIvUw0eGqT7Ww6xUx9VvdN.png","target":"../../../选择必修二  教参/Highlights/Page 077/Untitled.md","line":44},{"title":"https://remnote-user-data.s3.amazonaws.com/wGrQq35nd_51BcKJqVEVhwHBcrqOWmpT5vcmtAPdO5e2ApNgLImdA62olVSVzLwP_LTbAoSkW2ZYRl-BRtBpyMdPSnYmSZ60y9ESA_sX3yI7sz5j87bKEnErHKVBzClS.png","target":"../../../选择必修二  教参/Highlights/Page 078/Untitled.md","line":45},{"title":"https://remnote-user-data.s3.amazonaws.com/Nj734PgYINCo8thJadCb6ianFpSZqUAgmC3RAUNqtzHOcHSIeHJqriyV6FSsYy8XjCEzgZzBekqgLEuFWz6IHTuhpmpx--Y15qx7w5HQUSRlDhJ_1VQCOV-aEIFMaf8a.png","target":"../../../选择必修二  教参/Highlights/Page 083/Untitled.md","line":58},{"title":"1题集","target":"../../../pin/框架/1题集.md","line":62},{"title":"极值点","target":"../../../极值点.md","line":70},{"title":"极小值点是函数在该区间内的最小值点。 极值点出现在函数的驻点（一阶导数为零的点）或不可导点处（导数不存在）1","target":"https://blog.csdn.net/ma123rui/article/details/104704831","line":72},{"title":"2","target":"https://zhidao.baidu.com/question/389787422.html","line":72},{"title":"驻点","target":"../../../驻点.md","line":74},{"title":"拐点：拐点是函数凹凸性发生变化的点。在拐点处，函数的二阶导数发生变号。如果函数的二阶导数在某点从正变为负，或从负变为正，那么该点就是拐点。拐点通常对应函数图像的弯曲变化3","target":"https://www.cnblogs.com/wmzh/p/15516275.html","line":77},{"title":"概念 ","target":"../../../概念.md","line":84},{"title":"开区间","target":"../../../开区间.md","line":84},{"title":"导数及其应用","target":"../../../选修二/Highlights/Page 008/导数及其应用.md","line":85},{"title":"极限","target":"../../../极限.md","line":88},{"title":"２ 导数的几何意义","target":"../../../选修二/Highlights/Page 012/２ 导数的几何意义.md","line":89},{"title":"割线","target":"../../../割线.md","line":90},{"title":"驻点","target":"../../../驻点.md","line":92},{"title":"导函数","target":"../