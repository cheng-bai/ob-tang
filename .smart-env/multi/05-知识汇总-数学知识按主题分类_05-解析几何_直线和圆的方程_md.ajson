=\\tan \\varphi$ 。现在将图像沿水平方向平移，如下图所示。\n![","target":"https://cdn.mathpix.com/cropped/2025_02_16_9e2b4e805b8d5043fc44g-280.jpg?height=510&width=493&top_left_y=587&top_left_x=784","line":56}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1bypzhz","at":1771382884787}},"smart_blocks:05-知识汇总-数学知识按主题分类/05-解析几何/直线和圆的方程.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0723578,-0.0150339,0.08782903,-0.06250658,0.02599494,0.00076129,0.00612173,-0.01324177,0.03899924,-0.02300564,0.0093618,-0.03603369,0.03308385,0.01437382,0.02056561,0.03701799,-0.00143088,-0.03530413,-0.01014204,-0.04328306,0.09678473,-0.0552424,-0.00171768,0.00756097,0.03257668,-0.02408404,-0.00627927,-0.03640191,-0.00623798,-0.14950813,-0.0420551,-0.01108585,0.02891877,-0.01483855,-0.00673206,-0.04528917,-0.05195581,0.05233957,-0.03315957,0.01691963,0.0360085,0.01037178,0.05313915,-0.04605498,0.03490432,-0.01796588,0.01557977,-0.06629818,-0.00202796,-0.04174355,-0.07435604,-0.06543653,0.0025889,0.02101934,-0.04626141,0.02145329,0.04414983,0.04245266,0.03355957,0.04749547,0.06188325,0.02807943,-0.22084597,0.04080044,0.04755472,-0.03260705,0.0047207,0.00506917,0.07111505,0.02843918,-0.07316621,0.01028936,-0.03928117,0.04109097,0.03704897,0.02166531,-0.03663378,-0.04962872,-0.02258891,-0.03102298,-0.04221212,0.06865274,-0.00655092,0.00977202,-0.01745388,0.02050265,0.00211951,-0.07781994,0.01056744,0.02265465,0.00279927,-0.05722493,-0.03521735,0.05410913,-0.04389907,-0.00798487,0.00973986,0.02595535,-0.0395258,0.10494132,-0.04229925,0.03264216,0.02303554,-0.01187997,0.01790537,-0.03394077,-0.02677569,-0.04073438,-0.02298621,0.03647319,-0.02479124,-0.05155993,0.08684841,-0.06166697,-0.02781811,0.04639269,0.07548799,0.00278716,-0.02426289,0.02567206,-0.02487811,0.02756778,0.01999146,-0.00354649,0.03355428,-0.04151973,0.00188282,0.03917976,0.0904517,0.00861495,0.03183514,0.00307527,-0.05863672,-0.06195789,0.01595028,-0.07870712,0.00285027,0.03175378,0.02901137,-0.0894306,