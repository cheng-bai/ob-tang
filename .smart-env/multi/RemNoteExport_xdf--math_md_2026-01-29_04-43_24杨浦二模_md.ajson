.amazonaws.com/xjhmnDvkx-zAxKZeGuLxooKIeUiusFXewg5ZgcGk9SGmdQRXLegDqYiHe0W5NU2mi0cbi2LDCjZqqm5Ak26uaCfI3rxyZIvfXbcQfwjZl3r0l3CB3_tXLgIHjmoE_gz-.jpeg","line":13}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"oa3vf2","at":1769676329102}},"smart_blocks:RemNoteExport_xdf--math_md_2026-01-29_04-43/24杨浦二模.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.07258523,-0.03672002,0.04354589,-0.03502651,-0.0095525,-0.00094422,-0.07392619,-0.01112165,0.03025455,-0.00790342,0.00388626,-0.07091472,0.06821636,-0.0173394,0.0089799,0.00117958,-0.02050768,-0.02879396,-0.06098614,0.0060235,0.11618378,-0.04266107,0.01460512,-0.07688326,0.02037724,0.04442902,0.01329824,-0.03340184,-0.00496906,-0.20056206,-0.03581298,0.01633141,0.01247684,0.0156891,0.02581386,-0.06438167,-0.06915323,0.04329408,-0.00261903,0.06661439,0.0001098,0.07165682,0.03692532,-0.00212076,0.00268871,-0.11199616,-0.07311895,-0.01282653,0.03834875,-0.02673313,-0.02506091,-0.01665481,0.02234178,0.06012987,0.0101625,0.01010586,0.03587101,-0.00881413,0.03806114,0.04749159,0.07295156,0.03252095,-0.21947709,0.04854251,0.00005651,0.00035509,-0.03639756,-0.04557778,-0.01462225,0.0340491,-0.06021036,-0.00432712,-0.05649384,0.02764646,0.00512577,0.02087042,0.00563434,-0.06919865,-0.04736932,0.00161349,-0.0353195,0.04537064,-0.04228694,-0.00461423,0.01702221,0.01484631,-0.01350314,-0.03707084,0.02881987,0.00524099,-0.01199227,-0.00126561,-0.03001168,0.01481613,-0.03612464,-0.03358873,0.03391501,0.03532268,-0.06604654,0.06826553,-0.01477674,0.03406465,-0.04512527,-0.05547392,-0.00193316,-0.00949078,-0.03259518,-0.04526398,-0.03408971,-0.00512775,-0.00348487,-0.05592067,0.07462683,-0.05852699,-0.02780095,0.04415444,-0.00028494,0.02112119,-0.01480742,-0.01823409,0.01648322,0.02823302,0.03724737,-0.0001683,0.00515475,-0.00539939,-0.03088254,0.02469962,-0.01298091,0.06616762,0.02161546,0.040805,-0.02174006,0.00243986,-0.00712386,-0.01942822,-0.04726236,-0.03208731,-0.00161663,0.01725893,-0.0