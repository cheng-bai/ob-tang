phi$ 。现在将图像沿水平方向平移，如下图所示。\n![","target":"https://cdn.mathpix.com/cropped/2025_02_16_9e2b4e805b8d5043fc44g-280.jpg?height=510&width=493&top_left_y=587&top_left_x=784","line":56}],"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1bypzhz","at":1769671084520}},"smart_blocks:01-数学教学/知识体系/专题总结/直线和圆的方程.md#": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04419034,0.0047598,0.02646158,-0.03084063,0.01232904,-0.01192234,-0.00816276,-0.01151534,0.04965999,-0.01375822,0.01126806,-0.03363329,0.02272133,0.03094611,0.01007523,0.00841541,0.02247882,-0.04209864,-0.00846974,-0.03379457,0.10131592,-0.05660293,-0.01347522,-0.05251539,0.06747825,0.00966503,0.0164607,-0.05353839,0.03479749,-0.17086241,0.00538698,0.0177009,0.02945372,0.03920078,0.02736192,-0.02713205,-0.01565037,0.02804122,-0.06083968,0.01089703,0.03841599,0.04224715,0.04656623,-0.00085205,0.03446287,-0.00079385,-0.01539192,-0.03875491,0.00882391,-0.02834681,-0.05702864,-0.01680635,-0.02481456,0.02046606,-0.03986296,0.0373513,0.03759833,0.0518358,-0.00343922,0.00435259,0.02915511,0.00034572,-0.24146785,0.03796453,0.0564009,-0.02560471,0.01430603,0.01786808,0.06854274,0.07929367,-0.04129833,-0.00557282,0.00736745,0.00970071,0.02564822,0.0212192,0.00549282,-0.02540763,-0.01656906,-0.06977245,-0.01022661,0.07018519,0.00065379,-0.00388358,-0.02072917,0.03205753,-0.01923838,-0.11532872,-0.00221623,-0.00928639,0.04160331,-0.05682093,-0.02995992,0.02915145,-0.04281682,-0.01170762,-0.00777018,0.02407199,-0.04358632,0.10528432,-0.04750253,0.02393311,-0.00826636,-0.00512636,0.00131786,0.00569792,-0.00908142,-0.08114251,-0.01607051,0.02532709,-0.02111831,-0.01811217,0.0796319,-0.04395929,-0.00949181,0.06507961,0.06746606,0.0376219,-0.01979832,0.01938354,-0.00949258,0.03179751,-0.00695349,-0.04525964,0.02502436,-0.06874071,0.01321624,0.04866044,0.0603903,0.00942342,0.02827175,0.02801685,-0.0507818,-0.05340526,-0.00823399,-0.02146725,-0.03252991,0.0462939,0.00814013,-0.05177441,-0.02297347,-0.0570