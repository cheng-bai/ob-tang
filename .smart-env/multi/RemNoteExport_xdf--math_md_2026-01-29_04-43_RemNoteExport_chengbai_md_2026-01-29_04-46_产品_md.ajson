
"smart_sources:RemNoteExport_xdf--math_md_2026-01-29_04-43/RemNoteExport_chengbai_md_2026-01-29_04-46/产品.md": {"path":"RemNoteExport_xdf--math_md_2026-01-29_04-43/RemNoteExport_chengbai_md_2026-01-29_04-46/产品.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"xm2yri","at":1769676512454},"class_name":"SmartSource","last_import":{"mtime":1743227774000,"size":15189,"at":1769676512455,"hash":"xm2yri"},"blocks":{"#":[1,271],"##{1}":[1,1],"##{2}":[2,4],"##{3}":[5,12],"##{4}":[13,18],"##{5}":[19,19],"##{6}":[20,60],"##{7}":[61,62],"##{8}":[63,229],"##{9}":[267,271]},"outlinks":[{"title":"峰哥","target":"峰哥.md","line":5},{"title":"直播","target":"直播.md","line":8},{"title":"思维导图","target":"思维导图.md","line":13},{"title":"比如 remonte 可以做一个前端提示链接的功能，保持高亮。目的是解决思维导图可以非常轻松的现实不同主题之间的关系，利用图形。但是 remnote 这样的大纲笔记的双链形式还不够直观，被链接的 rem 不知道是哪一个链接了它，体验不够直观。","target":"💡P.A.R.A/😎归档/叮咚经历/找叮咚工作的积累/叮咚买菜招聘准备/自己的优势 ，特点  展现自己的品质  品质+细节/对于流程优化，和效率有追求。/自己的优势，自己产品能力的体现，会经常对喜欢产品like  remnote提出反馈意见，和社区里同样使用软件的小伙伴交流，并且帮助他们入门一些好用的技巧，也会冒出一些产品的新点子然后提交到论坛里和大家讨论。/比如 remonte 可以做一个前端提示链接的功能，保持高亮。目的是解决思维导图可以非常轻松的现实不同主题之间的关系，利用图形。但是 remnote 这样的大纲笔记的双链形式还不够直观，被链接的 rem 不知道是哪一个链接了它，体验不够直观。.md","line":18},{"title":"产品","target":"产品.md","line":20},{"title":"知乎","target":"知乎.md","line":61},{"title":"面试","target":"面试.md","line":81},{"title":"B站","target":"B站.md","line":267}],"task_lines":[2],"tasks":{"incomplete":{"all":[2],"top":[2]}},"codeblock_ranges":[]},
